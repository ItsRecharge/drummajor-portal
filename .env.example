# Drum Major Portal — environment variables
# Copy to .env for local dev, or place these in the systemd EnvironmentFile in
# production (/etc/drummajor-portal/portal.env, root-readable only).
# Never commit a filled-in version.

# PostgreSQL connection string (native Postgres on the same server)
DATABASE_URL="postgresql://portal:CHANGE_ME@localhost:5432/drummajor_portal?schema=public"

# AES-256-GCM master key for encrypting SMTP/Drive secrets at rest.
# Generate with:  openssl rand -base64 48
APP_ENCRYPTION_KEY="CHANGE_ME_min_32_chars_use_openssl_rand_base64_48"

# Auth.js (NextAuth) session signing secret.
# Generate with:  openssl rand -base64 32
AUTH_SECRET="CHANGE_ME_openssl_rand_base64_32"

# Public base URL of the portal (used in invite/verification/reset links).
NEXT_PUBLIC_BASE_URL="https://portal.example.org"
AUTH_URL="https://portal.example.org"

# Node environment
NODE_ENV="production"
